; Function Attrs: noinline nounwind optnone uwtable
define dso_local i32 @sum(i32 noundef %n, i32 noundef %m) #0 !dbg !10 {
entry:
  %retval = alloca i32, align 4
  %n.addr = alloca i32, align 4
  %m.addr = alloca i32, align 4
  store i32 %n, ptr %n.addr, align 4
    #dbg_declare(ptr %n.addr, !15, !DIExpression(), !16)
  store i32 %m, ptr %m.addr, align 4
    #dbg_declare(ptr %m.addr, !17, !DIExpression(), !18)
  %0 = load i32, ptr %n.addr, align 4, !dbg !19
  %cmp = icmp sle i32 %0, 0, !dbg !21
  br i1 %cmp, label %if.then, label %if.else, !dbg !21

if.then:                                          ; preds = %entry
  %1 = load i32, ptr %m.addr, align 4, !dbg !22
  %2 = load i32, ptr %n.addr, align 4, !dbg !24
  %add = add nsw i32 %1, %2, !dbg !25
  store i32 %add, ptr %retval, align 4, !dbg !26
  br label %return, !dbg !26

if.else:                                          ; preds = %entry
  %3 = load i32, ptr %n.addr, align 4, !dbg !27
  %sub = sub nsw i32 %3, 1, !dbg !29
  %4 = load i32, ptr %m.addr, align 4, !dbg !30
  %add1 = add nsw i32 %4, 1, !dbg !31
  %call = call i32 @sum(i32 noundef %sub, i32 noundef %add1), !dbg !32
  store i32 %call, ptr %retval, align 4, !dbg !33
  br label %return, !dbg !33

return:                                           ; preds = %if.else, %if.then
  %5 = load i32, ptr %retval, align 4, !dbg !34
  ret i32 %5, !dbg !34
}

; Function Attrs: noinline nounwind optnone uwtable
define dso_local i32 @no_main_recursive_sum_2() #0 !dbg !35 {
entry:
  %retval = alloca i32, align 4
  %a = alloca i32, align 4
  %b = alloca i32, align 4
  %res = alloca i32, align 4
    #dbg_declare(ptr %a, !38, !DIExpression(), !39)
  store i32 -100, ptr %a, align 4, !dbg !39
    #dbg_declare(ptr %b, !40, !DIExpression(), !41)
  store i32 3, ptr %b, align 4, !dbg !41
    #dbg_declare(ptr %res, !42, !DIExpression(), !43)
  %0 = load i32, ptr %a, align 4, !dbg !44
  %1 = load i32, ptr %b, align 4, !dbg !45
  %call = call i32 @sum(i32 noundef %0, i32 noundef %1), !dbg !46
  store i32 %call, ptr %res, align 4, !dbg !43
  %2 = load i32, ptr %res, align 4, !dbg !47
  %cmp = icmp sle i32 %2, 3, !dbg !48
  call void @svf_assert(i1 noundef zeroext %cmp), !dbg !49
  %3 = load i32, ptr %retval, align 4, !dbg !50
  ret i32 %3, !dbg !50
}

