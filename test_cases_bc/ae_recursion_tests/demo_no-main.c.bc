; Function Attrs: noinline nounwind optnone uwtable
define dso_local i32 @demo(i32 noundef %a) #0 !dbg !17 {
entry:
  %retval = alloca i32, align 4
  %a.addr = alloca i32, align 4
  store i32 %a, ptr %a.addr, align 4
    #dbg_declare(ptr %a.addr, !22, !DIExpression(), !23)
  %0 = load i32, ptr %a.addr, align 4, !dbg !24
  %cmp = icmp sge i32 %0, 10000, !dbg !26
  br i1 %cmp, label %if.then, label %if.end, !dbg !26

if.then:                                          ; preds = %entry
  %1 = load i32, ptr %a.addr, align 4, !dbg !27
  store i32 %1, ptr %retval, align 4, !dbg !28
  br label %return, !dbg !28

if.end:                                           ; preds = %entry
  %2 = load i32, ptr %a.addr, align 4, !dbg !29
  %add = add nsw i32 %2, 1, !dbg !30
  %call = call i32 @demo(i32 noundef %add), !dbg !31
  br label %return, !dbg !32

return:                                           ; preds = %if.end, %if.then
  %3 = load i32, ptr %retval, align 4, !dbg !32
  ret i32 %3, !dbg !32
}

; Function Attrs: noinline nounwind optnone uwtable
define dso_local i32 @no_main_demo() #0 !dbg !33 {
entry:
  %retval = alloca i32, align 4
  %result = alloca i32, align 4
    #dbg_declare(ptr %result, !36, !DIExpression(), !37)
  %call = call i32 @demo(i32 noundef 0), !dbg !38
  store i32 %call, ptr %result, align 4, !dbg !37
  %0 = load i32, ptr %result, align 4, !dbg !39
  call void @svf_print(i32 noundef %0, ptr noundef @.str), !dbg !40
  %1 = load i32, ptr %result, align 4, !dbg !41
  %cmp = icmp eq i32 %1, 10000, !dbg !42
  call void @svf_assert(i1 noundef zeroext %cmp), !dbg !43
  %2 = load i32, ptr %retval, align 4, !dbg !44
  ret i32 %2, !dbg !44
}

declare void @svf_print(i32 noundef, ptr noundef) #1

declare void @svf_assert(i1 noundef zeroext) #1

