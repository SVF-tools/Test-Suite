; Function Attrs: noinline nounwind optnone uwtable
define dso_local i32 @mc91(i32 noundef %p) #0 !dbg !10 {
entry:
  %retval = alloca i32, align 4
  %p.addr = alloca i32, align 4
  %p1 = alloca i32, align 4
  %p2 = alloca i32, align 4
  %result = alloca i32, align 4
  store i32 %p, ptr %p.addr, align 4
    #dbg_declare(ptr %p.addr, !15, !DIExpression(), !16)
  %0 = load i32, ptr %p.addr, align 4, !dbg !17
  %cmp = icmp sgt i32 %0, 100, !dbg !19
  br i1 %cmp, label %if.then, label %if.else, !dbg !19

if.then:                                          ; preds = %entry
  %1 = load i32, ptr %p.addr, align 4, !dbg !20
  %sub = sub nsw i32 %1, 10, !dbg !22
  store i32 %sub, ptr %retval, align 4, !dbg !23
  br label %return, !dbg !23

if.else:                                          ; preds = %entry
    #dbg_declare(ptr %p1, !24, !DIExpression(), !26)
  %2 = load i32, ptr %p.addr, align 4, !dbg !27
  %add = add nsw i32 %2, 11, !dbg !28
  store i32 %add, ptr %p1, align 4, !dbg !26
    #dbg_declare(ptr %p2, !29, !DIExpression(), !30)
  %3 = load i32, ptr %p1, align 4, !dbg !31
  %call = call i32 @mc91(i32 noundef %3), !dbg !32
  store i32 %call, ptr %p2, align 4, !dbg !30
    #dbg_declare(ptr %result, !33, !DIExpression(), !34)
  %4 = load i32, ptr %p2, align 4, !dbg !35
  %call1 = call i32 @mc91(i32 noundef %4), !dbg !36
  store i32 %call1, ptr %result, align 4, !dbg !34
  %5 = load i32, ptr %result, align 4, !dbg !37
  store i32 %5, ptr %retval, align 4, !dbg !38
  br label %return, !dbg !38

return:                                           ; preds = %if.else, %if.then
  %6 = load i32, ptr %retval, align 4, !dbg !39
  ret i32 %6, !dbg !39
}

; Function Attrs: noinline nounwind optnone uwtable
define dso_local i32 @no_main_recursive_mc91_8() #0 !dbg !40 {
entry:
  %retval = alloca i32, align 4
  %result = alloca i32, align 4
    #dbg_declare(ptr %result, !43, !DIExpression(), !44)
  %call = call i32 @mc91(i32 noundef 100), !dbg !45
  store i32 %call, ptr %result, align 4, !dbg !44
  %0 = load i32, ptr %result, align 4, !dbg !46
  %cmp = icmp sle i32 %0, 110, !dbg !47
  call void @svf_assert(i1 noundef zeroext %cmp), !dbg !48
  %1 = load i32, ptr %retval, align 4, !dbg !49
  ret i32 %1, !dbg !49
}

