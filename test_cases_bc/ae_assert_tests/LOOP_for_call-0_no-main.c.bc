; Function Attrs: noinline nounwind optnone uwtable
define dso_local i32 @add(i32 noundef %a) #0 !dbg !10 {
entry:
  %a.addr = alloca i32, align 4
  store i32 %a, ptr %a.addr, align 4
    #dbg_declare(ptr %a.addr, !15, !DIExpression(), !16)
  %0 = load i32, ptr %a.addr, align 4, !dbg !17
  %add = add nsw i32 %0, 1, !dbg !18
  ret i32 %add, !dbg !19
}

; Function Attrs: noinline nounwind optnone uwtable
define dso_local i32 @no_main_LOOP_for_call_0() #0 !dbg !20 {
entry:
  %retval = alloca i32, align 4
  %i = alloca i32, align 4
  %j = alloca i32, align 4
    #dbg_declare(ptr %i, !23, !DIExpression(), !24)
  store i32 0, ptr %i, align 4, !dbg !24
    #dbg_declare(ptr %j, !25, !DIExpression(), !26)
  store i32 0, ptr %j, align 4, !dbg !26
  store i32 0, ptr %i, align 4, !dbg !27
  br label %for.cond, !dbg !29

for.cond:                                         ; preds = %for.inc, %entry
  %0 = load i32, ptr %i, align 4, !dbg !30
  %cmp = icmp slt i32 %0, 5, !dbg !32
  br i1 %cmp, label %for.body, label %for.end, !dbg !33

for.body:                                         ; preds = %for.cond
  %1 = load i32, ptr %j, align 4, !dbg !34
  %call = call i32 @add(i32 noundef %1), !dbg !36
  store i32 %call, ptr %j, align 4, !dbg !37
  br label %for.inc, !dbg !38

for.inc:                                          ; preds = %for.body
  %2 = load i32, ptr %i, align 4, !dbg !39
  %inc = add nsw i32 %2, 1, !dbg !39
  store i32 %inc, ptr %i, align 4, !dbg !39
  br label %for.cond, !dbg !40, !llvm.loop !41

for.end:                                          ; preds = %for.cond
  %3 = load i32, ptr %i, align 4, !dbg !44
  %cmp1 = icmp eq i32 %3, 5, !dbg !45
  br i1 %cmp1, label %land.rhs, label %land.end, !dbg !46

land.rhs:                                         ; preds = %for.end
  %4 = load i32, ptr %j, align 4, !dbg !47
  %cmp2 = icmp sge i32 %4, 0, !dbg !48
  br label %land.end

land.end:                                         ; preds = %land.rhs, %for.end
  %5 = phi i1 [ false, %for.end ], [ %cmp2, %land.rhs ], !dbg !49
  call void @svf_assert(i1 noundef zeroext %5), !dbg !50
  %6 = load i32, ptr %retval, align 4, !dbg !51
  ret i32 %6, !dbg !51
}

declare void @svf_assert(i1 noundef zeroext) #1

