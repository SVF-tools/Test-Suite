  %6 = load ptr, ptr %i.addr, align 8, !dbg !33
  %7 = load i32, ptr %6, align 4, !dbg !34
  %add2 = add nsw i32 %7, 3, !dbg !35
  %8 = load ptr, ptr %i.addr, align 8, !dbg !36
