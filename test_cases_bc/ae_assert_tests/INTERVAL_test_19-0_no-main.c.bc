  %1 = load i32, ptr %0, align 4, !dbg !21
  %rem = srem i32 %1, 2, !dbg !22
  store i32 %rem, ptr %a, align 4, !dbg !19
  %2 = load i32, ptr %a, align 4, !dbg !23
  switch i32 %2, label %sw.default [
    i32 0, label %sw.bb
    i32 1, label %sw.bb1
  ], !dbg !24

sw.bb:                                            ; preds = %entry
