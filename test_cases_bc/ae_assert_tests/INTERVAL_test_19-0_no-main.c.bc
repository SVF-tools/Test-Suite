define dso_local i32 @no_main_INTERVAL_test_19_0() #0 !dbg !40 {
entry:
  %retval = alloca i32, align 4
  %i = alloca i32, align 4
    #dbg_declare(ptr %i, !43, !DIExpression(), !44)
  store i32 1, ptr %i, align 4, !dbg !44
  %0 = load i32, ptr %i, align 4, !dbg !45
  %cmp = icmp sge i32 %0, 0, !dbg !47
