define dso_local i32 @no_main_CAST_trunc() #0 !dbg !16 {
entry:
  %largeValue = alloca i64, align 8
  %truncatedValue = alloca i8, align 1
    #dbg_declare(ptr %largeValue, !21, !DIExpression(), !25)
  store i64 256, ptr %largeValue, align 8, !dbg !25
    #dbg_declare(ptr %truncatedValue, !26, !DIExpression(), !27)
  %0 = load i64, ptr %largeValue, align 8, !dbg !28
  %conv = trunc i64 %0 to i8, !dbg !29
  store i8 %conv, ptr %truncatedValue, align 1, !dbg !27
  %1 = load i8, ptr %truncatedValue, align 1, !dbg !30
  %conv1 = sext i8 %1 to i32, !dbg !30
  %cmp = icmp eq i32 %conv1, 0, !dbg !31
  call void @svf_assert(i1 noundef zeroext %cmp), !dbg !32
  ret i32 0, !dbg !33
}

