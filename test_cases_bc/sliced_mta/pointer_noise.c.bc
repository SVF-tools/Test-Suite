target triple = "x86_64-unknown-linux-gnu"

%struct.Node = type { i32, ptr }

@hot_b = dso_local global i32 0, align 4
@hot_a = dso_local global i32 0, align 4
@pool = dso_local global [32 x %struct.Node] zeroinitializer, align 16

; Function Attrs: noinline nounwind optnone uwtable
define dso_local ptr @worker_a(ptr noundef %arg) #0 {
entry:
  %arg.addr = alloca ptr, align 8
  %v = alloca i32, align 4
  store ptr %arg, ptr %arg.addr, align 8
  %0 = load ptr, ptr %arg.addr, align 8
  %1 = ptrtoint ptr %0 to i64
  %conv = trunc i64 %1 to i32
  store i32 %conv, ptr %v, align 4
  %2 = load i32, ptr %v, align 4
  %call = call i32 @pointer_noise(i32 noundef %2)
  %3 = load i32, ptr %v, align 4
  call void @write_hot(i32 noundef %3)
  ret ptr null
}

